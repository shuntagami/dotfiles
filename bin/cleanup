#!/usr/bin/env node

const fs = require('fs');
const os = require('os');
const path = require('path');

const targets = `
.DS_Store
.apport-ignore.xml
.babel.json
.calc_history
.dbshell
.dbus
.esd_auth
.evolution
.gconf
.gconfd
.gnome
.gnome2_private
.goutputstream*
.gstreamer-0.10
.gtk-bookmarks
.lesshst
.nautilus
.node_repl_history
.mysql_history
.php_history
.pulse
.pulse-cookie
.python_history
.rdbg_history
.recently-used.xbel*
.rediscli_history
.rnd
.sqlite_history
.swt
.thumbnails
.ts_node_repl_history
.utop-history
.v8flags.*
.w3m
.wget-hsts
.xsel.log
.xsession-errors
.xsession-errors.old
canary_debuglog.txt
tmux-client-*.log
.bash_history
.irb_history
.nuxtrc
.viminfo
.zcompdump
`.trim().split(/\s+/);

function wildcardToRegExp(pattern) {
  const escaped = pattern.replace(/[.+?^${}()|[\]\\]/g, '\\$&').replace(/\*/g, '.*');
  return new RegExp(`^${escaped}$`);
}

function matchingTargets(home, pattern) {
  if (!pattern.includes('*')) return [path.join(home, pattern)];

  const re = wildcardToRegExp(pattern);
  return fs.readdirSync(home)
    .filter(name => re.test(name))
    .map(name => path.join(home, name));
}

const home = os.homedir();

for (const pattern of targets) {
  for (const target of matchingTargets(home, pattern)) {
    console.log(`rm -rf ${target}`);
    fs.rmSync(target, { force: true, recursive: true });
  }
}

fs.writeFileSync(path.join(process.cwd(), 'SSLKEYLOGFILE.log'), '');
