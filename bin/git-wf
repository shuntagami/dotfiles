#!/usr/bin/env bash
# git wf : pick a changed file from any worktree and open it in $EDITOR.

set -euo pipefail

usage() {
  cat <<'EOF'
usage: git wf [options]

Pick a changed file from any worktree and open it in $EDITOR.

Options:
  -d, --diff   pick a file and open its diff in a pager
  -l, --list   list changed files without opening a selector
  -h           show this help

Selectors:
  fzf   preview diff/content; Enter opens file; Ctrl-D opens diff
  peco  select file without preview
EOF
}

bat_cmd() {
  if command -v bat >/dev/null 2>&1; then
    printf 'bat'
  elif command -v batcat >/dev/null 2>&1; then
    printf 'batcat'
  fi
}

show_file() {
  local wt="$1"
  local file="$2"
  local full="$wt/$file"
  local bat

  if [[ ! -e "$full" ]]; then
    echo "[git wf] file does not exist in worktree: $full" >&2
    return 1
  fi

  if [[ -d "$full" ]]; then
    find "$full" -maxdepth 2 -print | sed -n '1,200p'
    return 0
  fi

  bat=$(bat_cmd)
  if [[ -n "$bat" ]]; then
    "$bat" --color=always --style=numbers --paging=never -- "$full"
  else
    sed -n '1,240p' "$full"
  fi
}

show_diff() {
  local wt="$1"
  local file="$2"
  local printed=0

  if ! git -C "$wt" diff --quiet -- "$file" 2>/dev/null; then
    git -C "$wt" diff --color=always -- "$file" || true
    printed=1
  fi

  if ! git -C "$wt" diff --cached --quiet -- "$file" 2>/dev/null; then
    if (( printed )); then
      printf '\n'
    fi
    git -C "$wt" diff --cached --color=always -- "$file" || true
    printed=1
  fi

  if (( ! printed )); then
    show_file "$wt" "$file" || true
  fi
}

preview() {
  local wt="$1"
  local file="$2"
  local status="${3:-}"

  printf '\033[1m%s\033[0m  %s\n\n' "$status" "$wt/$file"

  if [[ "$status" == "??" ]]; then
    show_file "$wt" "$file" || true
  else
    show_diff "$wt" "$file"
  fi
}

collect_items() {
  local path branch line wt status raw_path display_path open_path
  local -a worktrees branches

  path=""
  branch=""
  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      worktree\ *)
        path=${line#worktree }
        ;;
      branch\ refs/heads/*)
        branch=${line#branch refs/heads/}
        ;;
      detached)
        branch="(detached)"
        ;;
      "")
        if [[ -n "$path" ]]; then
          worktrees+=("$path")
          branches+=("${branch:-?}")
        fi
        path=""
        branch=""
        ;;
    esac
  done < <(git worktree list --porcelain)

  if [[ -n "$path" ]]; then
    worktrees+=("$path")
    branches+=("${branch:-?}")
  fi

  for i in "${!worktrees[@]}"; do
    wt=${worktrees[$i]}
    branch=${branches[$i]}

    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      status=${line:0:2}
      raw_path=${line:3}
      display_path=$raw_path
      open_path=$raw_path

      if [[ "$status" == R* || "$status" == C* ]]; then
        if [[ "$raw_path" == *" -> "* ]]; then
          open_path=${raw_path##* -> }
        fi
      fi

      printf '%s\t%s\t%s\t%s\t%s\n' "$branch" "$status" "$display_path" "$wt" "$open_path"
    done < <(git -C "$wt" -c core.quotePath=false status --porcelain=v1 --untracked-files=all)
  done
}

if [[ "${1:-}" == "--preview" ]]; then
  shift
  preview "$@"
  exit 0
fi

open_diff=0
list_only=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -d|--diff)
      open_diff=1
      ;;
    -l|--list)
      list_only=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "[git wf] unknown arg: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

print_table() {
  local items="$1"

  if command -v column >/dev/null 2>&1; then
    {
      printf 'BRANCH\tST\tPATH\tWORKTREE\n'
      printf '%s\n' "$items" | awk -F '\t' '{ print $1 "\t" $2 "\t" $3 "\t" $4 }'
    } | column -t -s $'\t'
  else
    printf '%s\n' "$items" | awk -F '\t' '{ print $1 "\t" $2 "\t" $3 "\t" $4 }'
  fi
}

numbered_select() {
  local items="$1"
  local line n choice

  if [[ ! -t 0 || ! -t 1 ]]; then
    return 1
  fi

  n=0
  while IFS= read -r line; do
    n=$((n + 1))
    awk -F '\t' -v n="$n" '{ printf "%3d  %-24s %-2s %s\n", n, $1, $2, $3 }' <<< "$line"
  done <<< "$items" > /dev/tty

  printf 'select file number: ' > /dev/tty
  read -r choice < /dev/tty
  [[ "$choice" =~ ^[0-9]+$ ]] || return 1
  sed -n "${choice}p" <<< "$items"
}

select_item() {
  local items="$1"
  local selection key item
  local preview_cmd self_q

  if command -v fzf >/dev/null 2>&1; then
    printf -v self_q '%q' "$0"
    preview_cmd="$self_q --preview {4} {5} {2}"

    selection=$(
      printf '%s\n' "$items" |
        fzf \
          --ansi \
          --delimiter=$'\t' \
          --with-nth=1,2,3 \
          --header='Enter: open file  Ctrl-D: view diff' \
          --expect=ctrl-d \
          --preview="$preview_cmd" \
          --preview-window='right,70%,wrap'
    ) || return 1

    key=${selection%%$'\n'*}
    item=${selection#*$'\n'}
    [[ -n "$item" && "$item" != "$selection" ]] || return 1

    key=${key:-open}
    printf '%s\t%s\n' "$key" "$item"
    return 0
  fi

  if command -v peco >/dev/null 2>&1; then
    echo "[git wf] fzf not found; using peco without preview." >&2
    item=$(printf '%s\n' "$items" | peco) || return 1
    printf 'open\t%s\n' "$item"
    return $?
  fi

  if [[ -t 0 && -t 1 ]]; then
    echo "[git wf] neither fzf nor peco found; using numbered selection." >&2
    item=$(numbered_select "$items") || return 1
    printf 'open\t%s\n' "$item"
    return 0
  fi

  echo "[git wf] neither fzf nor peco found; printing changed files instead." >&2
  return 1
}

items=$(collect_items)
if [[ -z "$items" ]]; then
  echo "[git wf] no changed files in worktrees."
  exit 0
fi

if (( list_only )); then
  print_table "$items"
  exit 0
fi

selection=$(select_item "$items") || {
  print_table "$items" >&2
  exit 1
}

IFS=$'\t' read -r key branch status display_path wt open_path <<< "$selection"

if [[ "$key" == "ctrl-d" ]]; then
  open_diff=1
fi

if (( open_diff )); then
  if command -v less >/dev/null 2>&1; then
    show_diff "$wt" "$open_path" | less -R
  else
    show_diff "$wt" "$open_path"
  fi
  exit 0
fi

editor=${EDITOR:-vim}
full_path="$wt/$open_path"

if [[ -e "$full_path" ]]; then
  "$editor" "$full_path"
else
  echo "[git wf] selected file is deleted or unavailable; showing diff instead: $full_path" >&2
  if command -v less >/dev/null 2>&1; then
    show_diff "$wt" "$open_path" | less -R
  else
    show_diff "$wt" "$open_path"
  fi
fi
