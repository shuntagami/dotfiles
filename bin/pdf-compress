#!/usr/bin/env node

const fs = require('fs');
const { spawnSync } = require('child_process');

function showHelp() {
  console.log(`Usage: pdf-compress [options] <input_pdf> [output_pdf]

Compresses a PDF file attempting to replicate Acrobat's optimization.

Options:
  -s, --screen     Screen-quality (72 dpi) - Aggressive size reduction
  -e, --ebook      Ebook-quality (150 dpi) - Balanced (Default)
  -p, --printer    Printer-quality (300 dpi) - High quality
  --flatten        Force re-distill (PDF->PS->PDF). Use if normal compression fails.
                   (Warning: Can remove/alter links, forms, tags, structure)
  --grayscale      Convert to grayscale
  -h, --help       Show this help`);
}

function findCommand(candidates) {
  for (const command of candidates) {
    const result = spawnSync(command, ['--version'], {
      stdio: 'ignore',
      windowsHide: true,
    });
    if (!result.error) return command;
  }
  return null;
}

function run(command, args) {
  const result = spawnSync(command, args, {
    stdio: 'inherit',
    windowsHide: true,
  });
  if (result.error) throw result.error;
  if (result.status !== 0) process.exit(result.status);
}

let preset = '/ebook';
let dpi = '150';
let grayscale = false;
let flatten = false;
const positional = [];

for (const arg of process.argv.slice(2)) {
  switch (arg) {
    case '-s':
    case '--screen':
      preset = '/screen';
      dpi = '72';
      break;
    case '-e':
    case '--ebook':
      preset = '/ebook';
      dpi = '150';
      break;
    case '-p':
    case '--printer':
      preset = '/printer';
      dpi = '300';
      break;
    case '--flatten':
      flatten = true;
      break;
    case '--grayscale':
      grayscale = true;
      break;
    case '-h':
    case '--help':
      showHelp();
      process.exit(0);
      break;
    default:
      if (arg.startsWith('-')) {
        console.error(`Unknown option: ${arg}`);
        showHelp();
        process.exit(1);
      }
      positional.push(arg);
  }
}

if (positional.length === 0) {
  showHelp();
  process.exit(0);
}

const input = positional[0];
const output = positional[1] || input.replace(/(\.[^.]+)?$/, '_compressed$1');
const tmpGs = `${output}.gs.pdf`;
const tmpPs = `${output}.tmp.ps`;

if (!fs.existsSync(input)) {
  console.error(`Input not found: ${input}`);
  process.exit(1);
}

const gs = process.env.GS || findCommand(['gs', 'gswin64c', 'gswin32c']);
const qpdf = findCommand(['qpdf']);

if (!gs) {
  console.error('Error: ghostscript not installed. Install with brew, winget, or scoop.');
  process.exit(1);
}
if (!qpdf) {
  console.error('Error: qpdf not installed. Install with brew, winget, or scoop.');
  process.exit(1);
}

const gsOptions = [
  '-sDEVICE=pdfwrite',
  '-dCompatibilityLevel=1.5',
  `-dPDFSETTINGS=${preset}`,
  '-dNOPAUSE',
  '-dBATCH',
  '-dQUIET',
  '-dDetectDuplicateImages=true',
  '-dCompressFonts=true',
  '-dSubsetFonts=true',
  '-dDownsampleColorImages=true',
  '-dColorImageDownsampleType=/Bicubic',
  `-dColorImageResolution=${dpi}`,
  '-dDownsampleGrayImages=true',
  '-dGrayImageDownsampleType=/Bicubic',
  `-dGrayImageResolution=${dpi}`,
  '-dDownsampleMonoImages=true',
  '-dMonoImageDownsampleType=/Subsample',
  '-dMonoImageResolution=300',
  '-dJPEGQ=60',
];

if (grayscale) {
  gsOptions.push('-sColorConversionStrategy=Gray', '-dProcessColorModel=/DeviceGray');
}

console.log(`Processing ${input} -> ${output}`);

try {
  if (flatten) {
    const pdf2ps = findCommand(['pdf2ps']);
    if (!pdf2ps) {
      console.error('Error: pdf2ps not found. Install ghostscript.');
      process.exit(1);
    }

    console.log('Mode: Flatten (PDF -> PS -> PDF)');
    run(pdf2ps, [input, tmpPs]);
    run(gs, [...gsOptions, `-sOutputFile=${tmpGs}`, tmpPs]);
  } else {
    console.log('Mode: Optimize');
    run(gs, [...gsOptions, `-sOutputFile=${tmpGs}`, input]);
  }

  run(qpdf, ['--object-streams=generate', '--compress-streams=y', tmpGs, output]);
  console.log('Done.');
} finally {
  fs.rmSync(tmpGs, { force: true });
  fs.rmSync(tmpPs, { force: true });
}
