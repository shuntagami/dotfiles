#!/usr/bin/env -S deno run -A --ext=js
// @ts-nocheck
// Markdown を Google Doc（LINEメッセージ形式）に流し込む standalone CLI。
// gdoc2md（Doc→md）の逆変換にあたる。
//
// Deno で動くため repo 非依存・ローカル node_modules 不要。
//
// 対応する Markdown 構造:
//   - `<!-- tab: タイトル -->`         複数タブ。出現順に Doc のタブへ割り当てる
//   - `# ` / `## ` / `### `            HEADING_1 / 2 / 3（ドキュメント先頭の見出しのみ TITLE）
//   - `- ...` / `1. ...`               箇条書き・番号付きリスト
//   - Markdown テーブル                 Google Docs の表
//   - ` ``` ` で囲んだコードブロック    1x1 のグレー（#efefef）テーブル＝LINE 1通分
//   - それ以外の行                     NORMAL_TEXT 段落（空行も段落として保持）
//   - インライン **太字** と [文字](URL) リンクは書式付きで反映
//   - `{{name}}` 形式のプレースホルダーは全体を黄色ハイライト
//   - ` ```mermaid ` 等の言語付きフェンス  Doc では描画不可のため出力しない
//   - 画像参照 ![imageN] は文字としてそのまま残す（画像本体は手で貼り直す前提）
//   - 先頭の `>` 引用ヘッダや `---`、最初の `<!-- tab -->` / `＜…＞` 見出しより前は無視
//
// タブの割り当て:
//   - Markdown のタブ数 ≤ Doc のタブ数 が必須（タブ作成は Docs API 非対応のため）。
//   - Markdown のタブと Doc のタブを「出現順」で対応づける（タブ名では照合しない）。
//   - 余った Doc タブは触らない。
//   - `<!-- tab -->` が無い Markdown は最初のタブだけを対象にする。
//
// 冪等性: --doc-id を渡せば既存 Doc を再利用する。対象タブは毎回クリア→再構築されるので
// 同じ .md と同じ --doc-id を指定すれば何度実行しても同じ結果になる。
// --doc-id を省略した場合のみテンプレからの新規コピーを行う。
//
// Usage:
//   md2gdoc <md-path> [google-doc-url] [--name <doc-name>] [--folder <folder-id>] [--template <doc-id>] [--dry-run]
//   md2gdoc <md-path> --doc-url <google-doc-url>
//   md2gdoc <md-path> --doc-id <id>
//
// --dry-run: Google API を叩かず、パース結果（タブ・ブロック・メッセージ数）だけ表示する。
//
// 認証: ~/dotfiles/.env.local の GOOGLE_SERVICE_ACCOUNT_KEY 等を使う。

import { readFileSync, existsSync } from "node:fs";
import { resolve, isAbsolute } from "node:path";
import { homedir } from "node:os";

// 汎用ドキュメント雛形（見出し h1〜h6 の色定義のみを継承する用途・1タブ）
const DEFAULT_TEMPLATE_ID = "168k8wuUAYN3HQhWxlFi7icw_v9yH1ilL8dPr5oAKENA";

function printUsageAndExit(exitCode = 0) {
  const out = exitCode === 0 ? console.log : console.error;
  out(`Usage:
  md2gdoc <md-path> [google-doc-url]
  md2gdoc <md-path> --doc-url <google-doc-url>
  md2gdoc <md-path> --doc-id <doc-id>
  md2gdoc <md-path> --name <doc-name> [--folder <folder-id>]
  md2gdoc <md-path> --dry-run

Examples:
  md2gdoc ./LINEメッセージ.md 'https://docs.google.com/document/d/xxxxxxxx/edit'
  md2gdoc ./LINEメッセージ.md --doc-url 'https://docs.google.com/document/d/xxxxxxxx/edit'
  md2gdoc ./LINEメッセージ.md --name 'LINEメッセージ_新規'

Options:
  --doc-url <url>       既存の Google Doc をURLで指定して再構築
  --doc-id <id|url>     既存の Google Doc をIDまたはURLで指定して再構築
  --name <name>         新規作成時のDoc名
  --folder <id>         新規作成時のDriveフォルダID
  --template <id|url>   コピー元テンプレートDoc
  --dry-run             Google APIを書き込まず、パース結果だけ表示
  -h, --help, help      このヘルプを表示`);
  process.exit(exitCode);
}

function parseArgs(argv) {
  const out = { _: [] };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === "--") {
      out._.push(...argv.slice(i + 1));
      break;
    }
    if (!a.startsWith("--")) {
      out._.push(a);
      continue;
    }
    const key = a.slice(2);
    const next = argv[i + 1];
    if (next && !next.startsWith("--")) {
      out[key] = next;
      i++;
    } else {
      out[key] = true;
    }
  }
  return out;
}

function normalizeDocId(value) {
  if (typeof value !== "string") return null;
  const s = value.trim();
  const m = /\/document\/d\/([a-zA-Z0-9_-]+)/.exec(s) || /\/d\/([a-zA-Z0-9_-]+)/.exec(s);
  if (m) return m[1];
  return /^[a-zA-Z0-9_-]{20,}$/.test(s) ? s : null;
}

// --- args ---
const rawArgs = process.argv.slice(2);
if (!rawArgs.length || rawArgs[0] === "help" || rawArgs.includes("--help") || rawArgs.includes("-h")) {
  printUsageAndExit(0);
}

const args = parseArgs(rawArgs);
const mdPath = args._[0];
if (!mdPath) printUsageAndExit(2);

const docName = args.name || "LINEメッセージ_テンプレ";
const folderId = args.folder || null;
const templateId = normalizeDocId(args.template) || args.template || DEFAULT_TEMPLATE_ID;
const docTarget = args["doc-url"] || args.url || args["doc-id"] || args._[1] || null;
const existingDocId = docTarget ? normalizeDocId(docTarget) : null;
if (docTarget && !existingDocId) {
  console.error(`Google Doc URL / Doc ID を読み取れません: ${docTarget}`);
  console.error("");
  printUsageAndExit(2);
}
const dryRun = !!args["dry-run"];

// --- env (~/dotfiles/.env.local) ---
const ENV_PATH = resolve(homedir(), "dotfiles/.env.local");
if (!existsSync(ENV_PATH)) {
  console.error(`.env.local が見つかりません: ${ENV_PATH}`);
  process.exit(1);
}
for (const line of readFileSync(ENV_PATH, "utf8").split("\n")) {
  const m = line.match(/^([A-Z_][A-Z0-9_]*)=(.*)$/);
  if (!m) continue;
  let v = m[2];
  if (v.startsWith('"') && v.endsWith('"')) v = v.slice(1, -1);
  if (!process.env[m[1]]) process.env[m[1]] = v;
}

// 外部パッケージ解決: Deno なら npm: 指定、node なら bare specifier。
const NPM = typeof Deno !== "undefined" ? "npm:" : "";
const { google } = await import(`${NPM}googleapis`);

const md = readFileSync(isAbsolute(mdPath) ? mdPath : resolve(process.cwd(), mdPath), "utf8");

// --- auth ---
const keyJson = process.env.GOOGLE_SERVICE_ACCOUNT_KEY;
if (!keyJson) {
  console.error("GOOGLE_SERVICE_ACCOUNT_KEY が .env.local にありません。");
  process.exit(1);
}
const sanitized = keyJson.replace(/\n/g, "\\n").replace(/\r/g, "\\r").replace(/\t/g, "\\t");
const credentials = JSON.parse(sanitized);
const impersonateEmail = process.env.GOOGLE_IMPERSONATE_EMAIL;
const auth = new google.auth.GoogleAuth({
  credentials,
  scopes: [
    "https://www.googleapis.com/auth/documents",
    "https://www.googleapis.com/auth/drive",
  ],
  ...(impersonateEmail ? { clientOptions: { subject: impersonateEmail } } : {}),
});
const docs = google.docs({ version: "v1", auth });
const drive = google.drive({ version: "v3", auth });

// =================================================================
// Markdown パーサ
// =================================================================
// 出力: [{ title, blocks: Block[] }]   ← タブ単位
//   Block = { type:"heading", level:1|2|3, text }
//         | { type:"para", text }            ← 空行は text:"" の para
//         | { type:"list", items:[{ ordered, level, text }] }
//         | { type:"table", rows:string[][] }
//         | { type:"code", text }            ← コードブロック1通分（プレーンテキスト）

function parseDoc(text) {
  const lines = text.split("\n");
  const tabs = [];
  let current = null;
  let started = false;
  let i = 0;

  const ensureTab = (title) => {
    current = { title, blocks: [] };
    tabs.push(current);
  };

  while (i < lines.length) {
    const line = lines[i];

    const tabMatch = line.match(/^<!--\s*tab:\s*(.*?)\s*-->\s*$/);
    if (tabMatch) {
      started = true;
      ensureTab(tabMatch[1]);
      i++; continue;
    }

    const headingMatch = line.match(/^(#{1,3})\s+(.*\S)\s*$/);
    if (headingMatch) {
      const level = headingMatch[1].length;
      const htext = headingMatch[2].trim();
      if (!started) {
        // イントロ中: `＜…＞` で始まる H1 を境にコンテンツ開始（タブ markers が無い形式）
        if (level === 1 && htext.startsWith("＜")) {
          started = true;
        } else {
          i++; continue; // イントロ見出しは無視
        }
      }
      if (!current) ensureTab(null);
      current.blocks.push({ type: "heading", level, text: htext });
      i++; continue;
    }

    if (!started) { i++; continue; } // イントロ（`>` ヘッダ・`---`・空行など）

    const fenceMatch = line.match(/^```(\S*)\s*$/);
    if (fenceMatch) {
      const lang = fenceMatch[1];
      const buf = [];
      i++;
      while (i < lines.length && !/^```\s*$/.test(lines[i])) {
        buf.push(lines[i]);
        i++;
      }
      i++; // closing ```
      // 言語なしフェンス = LINE 1通分 → テーブル化。
      // 言語付きフェンス（```mermaid 等）= Doc では描画できないため出力しない（.md 専用）。
      if (lang === "") {
        current.blocks.push({ type: "code", text: buf.join("\n").replace(/\s+$/, "") });
      }
      continue;
    }

    if (line.trim() === "---") { i++; continue; } // 水平線は無視

    if (isTableStart(lines, i)) {
      const { rows, nextIndex } = parseTable(lines, i);
      current.blocks.push({ type: "table", rows });
      i = nextIndex;
      continue;
    }

    const listItem = parseListItem(line);
    if (listItem) {
      const items = [];
      while (i < lines.length) {
        const item = parseListItem(lines[i]);
        if (!item) break;
        items.push(item);
        i++;
      }
      current.blocks.push({ type: "list", items });
      continue;
    }

    current.blocks.push({ type: "para", text: line });
    i++;
  }
  return tabs;
}

function parseListItem(line) {
  const m = /^(\s*)([-*+]|\d+[.)])\s+(.*)$/.exec(line);
  if (!m) return null;
  const indent = m[1].replace(/\t/g, "    ").length;
  const level = indent >= 2 ? 1 + Math.floor((indent - 2) / 4) : 0;
  return {
    ordered: /^\d+[.)]$/.test(m[2]),
    level,
    text: m[3],
  };
}

function isTableStart(lines, index) {
  const header = splitTableRow(lines[index]);
  const delimiter = splitTableRow(lines[index + 1] ?? "");
  if (!header || !delimiter || header.length < 2 || delimiter.length !== header.length) return false;
  return delimiter.every((cell) => /^:?-{3,}:?$/.test(cell.trim()));
}

function parseTable(lines, index) {
  const header = splitTableRow(lines[index]).map((cell) => cell.trim());
  let i = index + 2; // separator row is skipped
  const rows = [header];
  while (i < lines.length) {
    const cells = splitTableRow(lines[i]);
    if (!cells) break;
    rows.push(cells.map((cell) => cell.trim()));
    i++;
  }
  const colCount = Math.max(...rows.map((row) => row.length));
  return {
    rows: rows.map((row) => row.concat(Array(colCount - row.length).fill(""))),
    nextIndex: i,
  };
}

function splitTableRow(line) {
  if (!line || !line.includes("|")) return null;
  let body = line.trim();
  if (body.startsWith("|")) body = body.slice(1);
  if (body.endsWith("|")) body = body.slice(0, -1);
  const cells = [];
  let cell = "";
  for (let i = 0; i < body.length; i++) {
    if (body[i] === "\\" && body[i + 1] === "|") {
      cell += "|";
      i++;
      continue;
    }
    if (body[i] === "|") {
      cells.push(cell);
      cell = "";
      continue;
    }
    cell += body[i];
  }
  cells.push(cell);
  return cells;
}

// 構造由来の空行を間引く: 空 para は「前後ともに非空 para」のときだけ残す
// （見出し・テーブルの直前直後の空行は落とす。本文内の段落区切りは保つ）
function cleanBlocks(blocks) {
  const isBlank = (b) => b && b.type === "para" && b.text.trim() === "";
  const out = [];
  for (let j = 0; j < blocks.length; j++) {
    const b = blocks[j];
    if (isBlank(b)) {
      const prev = out[out.length - 1];
      const next = blocks[j + 1];
      if (isBlank(prev) || !prev || prev.type !== "para") continue;
      if (isBlank(next) || !next || next.type !== "para") continue;
    }
    out.push(b);
  }
  return out;
}

// インライン書式: **太字** と [文字](URL) を剥がしてプレーンテキスト＋スタイル範囲を返す
function parseInline(raw) {
  let text = "";
  const ranges = [];
  let i = 0;
  while (i < raw.length) {
    if (raw.startsWith("**", i)) {
      const close = raw.indexOf("**", i + 2);
      if (close !== -1) {
        const inner = raw.slice(i + 2, close);
        const s = text.length;
        text += inner;
        if (text.length > s) {
          ranges.push({ start: s, end: text.length, style: { bold: true }, fields: "bold" });
        }
        i = close + 2;
        continue;
      }
    }
    const linkM = /^\[([^\]]*)\]\(([^)]+)\)/.exec(raw.slice(i));
    if (linkM) {
      const s = text.length;
      text += linkM[1];
      if (text.length > s) {
        ranges.push({ start: s, end: text.length, style: { link: { url: linkM[2] } }, fields: "link" });
      }
      i += linkM[0].length;
      continue;
    }
    text += raw[i];
    i++;
  }
  ranges.push(...placeholderRanges(text));
  return { text, ranges };
}

function placeholderRanges(text) {
  const ranges = [];
  const re = /\{\{[^{}\n]*\}\}/g;
  let m;
  while ((m = re.exec(text)) !== null) {
    ranges.push({
      start: m.index,
      end: m.index + m[0].length,
      style: { backgroundColor: PLACEHOLDER_BG },
      fields: "backgroundColor",
    });
  }
  return ranges;
}

function isCenteredHeading(block) {
  return block.type === "heading" && block.level === 1 && /^＜.*＞$/.test(block.text.trim());
}

// =================================================================
// Doc ヘルパ
// =================================================================
async function getAllTabs(documentId) {
  const doc = (await docs.documents.get({ documentId, includeTabsContent: true })).data;
  return doc.tabs ?? [];
}

async function getTab(documentId, tabId) {
  const tabs = await getAllTabs(documentId);
  const tab = tabs.find((t) => t.tabProperties?.tabId === tabId);
  if (!tab) throw new Error(`tabId not found: ${tabId}`);
  return tab;
}

async function getTabEndIndex(documentId, tabId) {
  const tab = await getTab(documentId, tabId);
  const content = tab.documentTab?.body?.content ?? [];
  return content[content.length - 1]?.endIndex ?? 2;
}

async function getLastTableLocation(documentId, tabId) {
  const tab = await getTab(documentId, tabId);
  const content = tab.documentTab?.body?.content ?? [];
  for (let i = content.length - 1; i >= 0; i--) {
    const el = content[i];
    if (el.table) {
      const cell = el.table?.tableRows?.[0]?.tableCells?.[0];
      const para = cell?.content?.[0];
      if (typeof el.startIndex !== "number" || typeof para?.startIndex !== "number") continue;
      const prev = i > 0 ? content[i - 1] : null;
      return { tableStart: el.startIndex, cellStart: para.startIndex, prev };
    }
  }
  return null;
}

async function getLastTableGrid(documentId, tabId) {
  const tab = await getTab(documentId, tabId);
  const content = tab.documentTab?.body?.content ?? [];
  for (let i = content.length - 1; i >= 0; i--) {
    const el = content[i];
    if (!el.table || typeof el.startIndex !== "number") continue;
    const cells = [];
    for (const row of el.table.tableRows ?? []) {
      cells.push((row.tableCells ?? []).map((cell) => cell.content?.[0]?.startIndex ?? null));
    }
    return { tableStart: el.startIndex, cells };
  }
  return null;
}

function isEmptyParagraph(el) {
  const elements = el?.paragraph?.elements ?? [];
  return elements.length === 1 && elements[0].textRun?.content === "\n";
}

async function batchUpdate(documentId, requests) {
  if (!requests.length) return;
  await docs.documents.batchUpdate({ documentId, requestBody: { requests } });
}

async function clearTab(documentId, tabId) {
  const lastEnd = await getTabEndIndex(documentId, tabId);
  if (lastEnd > 2) {
    await batchUpdate(documentId, [
      { deleteContentRange: { range: { startIndex: 1, endIndex: lastEnd - 1, segmentId: "", tabId } } },
    ]);
  }
}

const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

const PLACEHOLDER_BG = { color: { rgbColor: { red: 1, green: 1, blue: 0 } } };
// Google Docs「明るいグレー2」: #f3f3f3（LINE 配信 Doc の慣習色）
const CELL_BG = { color: { rgbColor: { red: 0.9529412, green: 0.9529412, blue: 0.9529412 } } };
// セルボーダーは 1pt 白。テーブルの境目を背景になじませる手法。
const WHITE = { color: { rgbColor: { red: 1, green: 1, blue: 1 } } };
const CELL_BORDER = {
  color: WHITE,
  width: { magnitude: 1, unit: "PT" },
  dashStyle: "SOLID",
};

const HEADING_STYLE = { 1: "HEADING_1", 2: "HEADING_2", 3: "HEADING_3" };
const LIST_PRESET = {
  ordered: "NUMBERED_DECIMAL_ALPHA_ROMAN",
  unordered: "BULLET_DISC_CIRCLE_SQUARE",
};
const TABLE_BORDER = {
  color: { color: { rgbColor: { red: 0.8, green: 0.8, blue: 0.8 } } },
  width: { magnitude: 0.5, unit: "PT" },
  dashStyle: "SOLID",
};

async function appendList(documentId, tabId, items) {
  if (!items.length) return;
  const start = (await getTabEndIndex(documentId, tabId)) - 1;
  let cursor = start;
  const paras = [];
  const requests = [];

  for (const item of items) {
    const { text, ranges } = parseInline(item.text);
    const tabs = "\t".repeat(Math.max(0, item.level));
    const paraStart = cursor;
    const textStart = paraStart + tabs.length;
    requests.push({ insertText: { text: tabs + text + "\n", location: { index: cursor, tabId } } });
    cursor += tabs.length + text.length + 1;
    paras.push({
      ordered: item.ordered,
      tabs: tabs.length,
      start: paraStart,
      end: cursor,
    });
    requests.push({
      updateParagraphStyle: {
        range: { startIndex: paraStart, endIndex: paraStart + 1, tabId },
        paragraphStyle: { namedStyleType: "NORMAL_TEXT", alignment: "START" },
        fields: "namedStyleType,alignment",
      },
    });
    if (text.length > 0) {
      requests.push({
        updateTextStyle: {
          range: { startIndex: textStart, endIndex: textStart + text.length, tabId },
          textStyle: { fontSize: { magnitude: 11, unit: "PT" } },
          fields: "fontSize",
        },
      });
    }
    for (const r of ranges) {
      if (r.end <= r.start) continue;
      requests.push({
        updateTextStyle: {
          range: { startIndex: textStart + r.start, endIndex: textStart + r.end, tabId },
          textStyle: r.style,
          fields: r.fields,
        },
      });
    }
  }

  const baseOrdered = items[0].ordered;
  requests.push({
    createParagraphBullets: {
      range: { startIndex: start, endIndex: cursor, tabId },
      bulletPreset: baseOrdered ? LIST_PRESET.ordered : LIST_PRESET.unordered,
    },
  });
  await batchUpdate(documentId, requests);

  let removedTabs = 0;
  const overrideRequests = [];
  for (const p of paras) {
    const shiftedStart = p.start - removedTabs;
    const shiftedEnd = p.end - removedTabs - p.tabs;
    if (p.ordered !== baseOrdered) {
      overrideRequests.push({
        createParagraphBullets: {
          range: { startIndex: shiftedStart, endIndex: shiftedEnd, tabId },
          bulletPreset: p.ordered ? LIST_PRESET.ordered : LIST_PRESET.unordered,
        },
      });
    }
    removedTabs += p.tabs;
  }
  await batchUpdate(documentId, overrideRequests);
}

async function appendMarkdownTable(documentId, tabId, rows) {
  const rowCount = rows.length;
  const colCount = Math.max(...rows.map((row) => row.length));
  if (!rowCount || !colCount) return;

  const end = await getTabEndIndex(documentId, tabId);
  await batchUpdate(documentId, [
    { insertTable: { rows: rowCount, columns: colCount, location: { index: end - 1, tabId } } },
  ]);
  await sleep(1200);

  const grid = await getLastTableGrid(documentId, tabId);
  if (!grid) throw new Error("markdown table not found after insert");

  const cellJobs = [];
  for (let r = 0; r < rowCount; r++) {
    for (let c = 0; c < colCount; c++) {
      const cellStart = grid.cells?.[r]?.[c];
      if (typeof cellStart !== "number") continue;
      const { text, ranges } = parseInline(rows[r]?.[c] ?? "");
      if (!text.length) continue;
      cellJobs.push({ rowIndex: r, cellStart, text, ranges });
    }
  }
  cellJobs.sort((a, b) => b.cellStart - a.cellStart);

  const requests = [
    {
      updateTableCellStyle: {
        tableStartLocation: { index: grid.tableStart, tabId },
        tableCellStyle: {
          borderTop: TABLE_BORDER,
          borderRight: TABLE_BORDER,
          borderBottom: TABLE_BORDER,
          borderLeft: TABLE_BORDER,
        },
        fields: "borderTop,borderRight,borderBottom,borderLeft",
      },
    },
    {
      updateTableColumnProperties: {
        tableStartLocation: { index: grid.tableStart, tabId },
        columnIndices: Array.from({ length: colCount }, (_, i) => i),
        tableColumnProperties: { widthType: "EVENLY_DISTRIBUTED" },
        fields: "widthType",
      },
    },
  ];

  for (const job of cellJobs) {
    requests.push(
      { insertText: { text: job.text, location: { index: job.cellStart, tabId } } },
      {
        updateParagraphStyle: {
          range: { startIndex: job.cellStart, endIndex: job.cellStart + job.text.length, tabId },
          paragraphStyle: { namedStyleType: "NORMAL_TEXT", lineSpacing: 120 },
          fields: "namedStyleType,lineSpacing",
        },
      },
      {
        updateTextStyle: {
          range: { startIndex: job.cellStart, endIndex: job.cellStart + job.text.length, tabId },
          textStyle: {
            fontSize: { magnitude: 10, unit: "PT" },
            ...(job.rowIndex === 0 ? { bold: true } : {}),
          },
          fields: job.rowIndex === 0 ? "fontSize,bold" : "fontSize",
        },
      },
    );
    for (const r of job.ranges) {
      if (r.end <= r.start) continue;
      requests.push({
        updateTextStyle: {
          range: { startIndex: job.cellStart + r.start, endIndex: job.cellStart + r.end, tabId },
          textStyle: r.style,
          fields: r.fields,
        },
      });
    }
  }
  await batchUpdate(documentId, requests);
  await sleep(1200);
}

// コードブロック1通分を 1x1 グレーテーブルとして末尾に追加する
async function appendTable(documentId, tabId, cellText) {
  const end = await getTabEndIndex(documentId, tabId);
  const cursor = end - 1;
  // insertTable 自体が必要な段落を作るため、追加の改行は入れない。
  await batchUpdate(documentId, [
    { insertTable: { rows: 1, columns: 1, location: { index: cursor, tabId } } },
  ]);
  await sleep(1200);

  const loc = await getLastTableLocation(documentId, tabId);
  if (!loc) throw new Error("table not found after insert");
  if (isEmptyParagraph(loc.prev)) {
    await batchUpdate(documentId, [
      {
        updateParagraphStyle: {
          range: { startIndex: loc.prev.startIndex, endIndex: loc.prev.startIndex + 1, tabId },
          paragraphStyle: { namedStyleType: "NORMAL_TEXT", alignment: "START" },
          fields: "namedStyleType,alignment",
        },
      },
    ]);
  }

  const text = cellText.length ? cellText : " ";
  const placeholderRequests = placeholderRanges(text).map((r) => ({
    updateTextStyle: {
      range: { startIndex: loc.cellStart + r.start, endIndex: loc.cellStart + r.end, tabId },
      textStyle: r.style,
      fields: r.fields,
    },
  }));
  await batchUpdate(documentId, [
    { insertText: { text, location: { index: loc.cellStart, tabId } } },
    {
      updateParagraphStyle: {
        range: { startIndex: loc.cellStart, endIndex: loc.cellStart + text.length, tabId },
        paragraphStyle: { namedStyleType: "NORMAL_TEXT", lineSpacing: 120 },
        fields: "namedStyleType,lineSpacing",
      },
    },
    {
      updateTextStyle: {
        range: { startIndex: loc.cellStart, endIndex: loc.cellStart + text.length, tabId },
        textStyle: { fontSize: { magnitude: 11, unit: "PT" } },
        fields: "fontSize",
      },
    },
    ...placeholderRequests,
    {
      updateTableCellStyle: {
        tableStartLocation: { index: loc.tableStart, tabId },
        tableCellStyle: {
          backgroundColor: CELL_BG,
          borderTop: CELL_BORDER,
          borderRight: CELL_BORDER,
          borderBottom: CELL_BORDER,
          borderLeft: CELL_BORDER,
        },
        fields: "backgroundColor,borderTop,borderRight,borderBottom,borderLeft",
      },
    },
    {
      updateTableColumnProperties: {
        tableStartLocation: { index: loc.tableStart, tabId },
        columnIndices: [0],
        tableColumnProperties: { widthType: "EVENLY_DISTRIBUTED" },
        fields: "widthType",
      },
    },
  ]);
  await sleep(1200);
}

// 1タブ分のブロック列を Doc に流し込む。
// 連続する非テーブルブロック（見出し・段落）は1回の batchUpdate にまとめる。
async function buildTab(documentId, tabId, blocks, state) {
  let pending = [];
  let cursor = null;

  const flush = async () => {
    if (pending.length) await batchUpdate(documentId, pending);
    pending = [];
    cursor = null;
  };

  for (const block of blocks) {
    if (block.type === "code") {
      await flush();
      await appendTable(documentId, tabId, block.text);
      continue;
    }
    if (block.type === "list") {
      await flush();
      await appendList(documentId, tabId, block.items);
      continue;
    }
    if (block.type === "table") {
      await flush();
      await appendMarkdownTable(documentId, tabId, block.rows);
      continue;
    }

    if (cursor === null) {
      cursor = (await getTabEndIndex(documentId, tabId)) - 1;
    }

    let namedStyle;
    if (block.type === "heading") {
      namedStyle = state.firstHeadingDone ? HEADING_STYLE[block.level] : "TITLE";
      // 2つ目以降の見出しの前に空行を1つ入れる。
      // 転記先Docの見出しスタイルに余白が無いと、直前のテーブル・本文と密着して読みづらいため。
      if (state.firstHeadingDone) {
        pending.push({ insertText: { text: "\n", location: { index: cursor, tabId } } });
        pending.push({
          updateParagraphStyle: {
            range: { startIndex: cursor, endIndex: cursor + 1, tabId },
            paragraphStyle: { namedStyleType: "NORMAL_TEXT", alignment: "START" },
            fields: "namedStyleType,alignment",
          },
        });
        cursor += 1;
      }
      state.firstHeadingDone = true;
    } else {
      namedStyle = "NORMAL_TEXT";
    }

    const { text, ranges } = parseInline(block.text);
    const centeredHeading = isCenteredHeading(block);
    const start = cursor;
    pending.push({ insertText: { text: text + "\n", location: { index: cursor, tabId } } });
    cursor += text.length + 1;
    pending.push({
      updateParagraphStyle: {
        range: { startIndex: start, endIndex: start + 1, tabId },
        paragraphStyle: {
          namedStyleType: namedStyle,
          ...(centeredHeading ? { alignment: "CENTER" } : {}),
          ...(block.type !== "heading" ? { alignment: "START" } : {}),
        },
        fields: block.type !== "heading" || centeredHeading ? "namedStyleType,alignment" : "namedStyleType",
      },
    });
    if (centeredHeading && text.length > 0) {
      pending.push({
        updateTextStyle: {
          range: { startIndex: start, endIndex: start + text.length, tabId },
          textStyle: { fontSize: { magnitude: 18, unit: "PT" } },
          fields: "fontSize",
        },
      });
    } else if (block.type !== "heading" && text.length > 0) {
      pending.push({
        updateTextStyle: {
          range: { startIndex: start, endIndex: start + text.length, tabId },
          textStyle: { fontSize: { magnitude: 11, unit: "PT" } },
          fields: "fontSize",
        },
      });
    }
    for (const r of ranges) {
      if (r.end <= r.start) continue;
      pending.push({
        updateTextStyle: {
          range: { startIndex: start + r.start, endIndex: start + r.end, tabId },
          textStyle: r.style,
          fields: r.fields,
        },
      });
    }
  }
  await flush();
}

// =================================================================
// main
// =================================================================
const mdTabs = parseDoc(md).map((t) => ({ title: t.title, blocks: cleanBlocks(t.blocks) }));
if (!mdTabs.length) {
  console.error("Markdown からコンテンツを検出できませんでした（`<!-- tab -->` も `＜…＞` 見出しも無い）。");
  process.exit(1);
}
console.error(`Markdown: ${mdTabs.length} タブ検出`);
for (const t of mdTabs) {
  const msgs = t.blocks.filter((b) => b.type === "code").length;
  console.error(`  - ${t.title ?? "(タブ指定なし)"}: ${t.blocks.length} ブロック / ${msgs} メッセージ`);
}

if (dryRun) {
  for (const t of mdTabs) {
    console.error(`\n── ${t.title ?? "(タブ指定なし)"} ──`);
    for (const b of t.blocks) {
      if (b.type === "heading") console.error(`  H${b.level}  ${b.text}`);
      else if (b.type === "code") console.error(`  [msg] ${b.text.split("\n")[0].slice(0, 40)}… (${b.text.split("\n").length}行)`);
      else if (b.type === "list") console.error(`  list ${b.items.length}項目`);
      else if (b.type === "table") console.error(`  table ${b.rows.length}x${b.rows[0]?.length ?? 0}`);
      else console.error(`  p   ${b.text === "" ? "(空行)" : b.text.slice(0, 50)}`);
    }
  }
  console.error("\n(--dry-run のため Google Doc は変更していません)");
  process.exit(0);
}

let newDocId;
if (existingDocId) {
  console.error(`\nReusing existing doc ${existingDocId} (idempotent rebuild)...`);
  newDocId = existingDocId;
} else {
  console.error(`\nCopying template ${templateId}...`);
  const copyResp = await drive.files.copy({
    fileId: templateId,
    requestBody: { name: docName, ...(folderId ? { parents: [folderId] } : {}) },
    supportsAllDrives: true,
  });
  newDocId = copyResp.data.id;
  console.error(`New doc: ${newDocId}`);
}

const docTabs = await getAllTabs(newDocId);
if (!docTabs.length) throw new Error("Doc にタブがありません");
if (mdTabs.length > docTabs.length) {
  console.error(
    `\n✗ Markdown は ${mdTabs.length} タブ必要ですが、対象 Doc は ${docTabs.length} タブしかありません。`,
  );
  console.error("  Docs API はタブを作成できません。対象 Doc / テンプレを必要なタブ数に手動で増やしてから再実行してください。");
  process.exit(1);
}

console.error("\nタブ割り当て（Markdown 出現順 → Doc 出現順）:");
const assignments = mdTabs.map((t, i) => {
  const docTab = docTabs[i];
  console.error(`  [${i + 1}] ${t.title ?? "(指定なし)"}  →  Docタブ「${docTab.tabProperties?.title ?? "?"}」`);
  return { mdTab: t, tabId: docTab.tabProperties?.tabId };
});
if (docTabs.length > mdTabs.length) {
  console.error(`  ※ 残り ${docTabs.length - mdTabs.length} タブは変更しません。`);
}

const state = { firstHeadingDone: false };
for (let i = 0; i < assignments.length; i++) {
  const { mdTab, tabId } = assignments[i];
  console.error(`\n[タブ ${i + 1}/${assignments.length}] ${mdTab.title ?? "(指定なし)"} を再構築...`);
  await clearTab(newDocId, tabId);
  const msgTotal = mdTab.blocks.filter((b) => b.type === "code").length;
  await buildTab(newDocId, tabId, mdTab.blocks, state);
  console.error(`  ✓ ${msgTotal} メッセージを反映`);
}

console.error("\n✓ Done.");
console.error("※ 画像 ![imageN] は文字として残っています。Doc 上で実画像に貼り替えてください。");
console.log(`https://docs.google.com/document/d/${newDocId}/edit`);
