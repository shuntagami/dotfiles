#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

function showHelp() {
  console.log(`使い方: merge_pdf <original_pdf> <total_pages>
       merge_pdf -h

オプション:
  -h            このヘルプメッセージを表示

引数:
  <original_pdf>   元のPDFファイルのパス
  <total_pages>    作成する総ページ数`);
}

const args = process.argv.slice(2);
if (args.length !== 2 || args[0] === '-h') {
  showHelp();
  process.exit(0);
}

const originalPdf = path.resolve(args[0]);
const totalPages = Number(args[1]);

if (!fs.existsSync(originalPdf)) {
  console.error(`PDF not found: ${originalPdf}`);
  process.exit(1);
}

if (!Number.isInteger(totalPages) || totalPages < 1) {
  console.error('total_pages must be a positive integer');
  process.exit(1);
}

const outputDirectory = process.cwd();
const parsed = path.parse(originalPdf);
const tempFiles = [];
const inputs = [originalPdf];

try {
  for (let i = 2; i <= totalPages; i++) {
    const newPdf = path.join(outputDirectory, `${parsed.name}_${i}.pdf`);
    fs.copyFileSync(originalPdf, newPdf);
    tempFiles.push(newPdf);
    inputs.push(newPdf);
  }

  const mergedOutput = path.join(outputDirectory, `${parsed.name}_${totalPages}page.pdf`);
  const result = spawnSync('cpdf', [...inputs, '-o', mergedOutput], {
    stdio: 'inherit',
    windowsHide: true,
  });

  if (result.error) throw result.error;
  if (result.status !== 0) process.exit(result.status);

  console.log(`${mergedOutput} generated`);
} catch (error) {
  console.error(`merge_pdf failed: ${error.message}`);
  process.exitCode = 1;
} finally {
  for (const tempFile of tempFiles) {
    fs.rmSync(tempFile, { force: true });
  }
}
