#!/bin/bash

# Copy downloaded plain text files to clipboard.
# Called by the Folder Action script when new items are added to ~/Downloads.
# Usage: watch-downloads-copy <file_path>

file="$1"
[ -f "$file" ] || exit 0

# Skip browser temp files (still downloading)
case "$file" in
  *.crdownload|*.part|*.download) exit 0 ;;
esac

mime=$(file --brief --mime-type "$file")
if [[ "$mime" == text/* ]]; then
  pbcopy < "$file"
  osascript -e "display notification \"Copied: $(basename "$file")\" with title \"Clipboard\""
fi
