#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

const dotfiles = process.env.DOTFILES || path.resolve(__dirname, '..');
const filePath = path.join(dotfiles, 'static', 'emoji-test.txt');
const data = fs.readFileSync(filePath, 'utf8');

const emojis = data.split('\n')
  .filter(line => line.includes('; fully-qualified') && !line.startsWith('#'))
  .map(line =>
    line.split(';')[0].trim().split(' ')
      .map(code => String.fromCodePoint(parseInt(code, 16)))
      .join('')
  );

console.log(emojis.join(' '));
