#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

const HELP = `Upload an image to catbox.moe and get the URL

Usage: upload_image path/to/your/image.jpg
`;

const arg = process.argv[2];

if (!arg || arg === '-h' || arg === '--help') {
  process.stdout.write(HELP);
  process.exit(arg ? 0 : 1);
}

(async () => {
  const filePath = path.resolve(arg);
  if (!fs.existsSync(filePath)) {
    console.error(`File not found: ${arg}`);
    process.exit(1);
  }

  const form = new FormData();
  form.append('reqtype', 'fileupload');
  const blob = new Blob([fs.readFileSync(filePath)]);
  form.append('fileToUpload', blob, path.basename(filePath));

  const res = await fetch('https://catbox.moe/user/api.php', { method: 'POST', body: form });
  const body = (await res.text()).trim();

  if (!res.ok) {
    console.error(`Failed to upload image: ${res.status} ${body}`);
    process.exit(1);
  }

  process.stdout.write(body + '\n');
})();
