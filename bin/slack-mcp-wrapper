#!/usr/bin/env node

const fs = require('fs');
const os = require('os');
const path = require('path');
const { spawn } = require('child_process');

function parseEnv(content) {
  const env = {};
  for (const rawLine of content.split(/\r?\n/)) {
    const line = rawLine.trim();
    if (!line || line.startsWith('#')) continue;

    const match = line.match(/^([A-Za-z_][A-Za-z0-9_]*)=(.*)$/);
    if (!match) continue;

    let value = match[2].trim();
    if (
      (value.startsWith('"') && value.endsWith('"')) ||
      (value.startsWith("'") && value.endsWith("'"))
    ) {
      value = value.slice(1, -1);
    }
    env[match[1]] = value;
  }
  return env;
}

async function fetchTeamId(token) {
  const res = await fetch('https://slack.com/api/auth.test', {
    headers: { Authorization: `Bearer ${token}` },
  });
  const data = await res.json();
  if (!data.ok) {
    throw new Error(`Slack auth.test failed: ${data.error || 'unknown'}`);
  }
  if (!data.team_id) {
    throw new Error('Slack auth.test did not return team_id');
  }
  return data.team_id;
}

(async () => {
  const envFile = process.env.SLACK_MCP_ENV_FILE ||
    path.join(os.homedir(), '.config', 'mcp', 'slack.env');

  if (fs.existsSync(envFile)) {
    Object.assign(process.env, parseEnv(fs.readFileSync(envFile, 'utf8')));
  }

  if (!process.env.SLACK_BOT_TOKEN) {
    console.error(`SLACK_BOT_TOKEN is not set. Create ${envFile} or export SLACK_BOT_TOKEN.`);
    process.exit(1);
  }

  if (!process.env.SLACK_TEAM_ID) {
    process.env.SLACK_TEAM_ID = await fetchTeamId(process.env.SLACK_BOT_TOKEN);
  }

  const npx = process.platform === 'win32' ? 'npx.cmd' : 'npx';
  const child = spawn(npx, ['-y', '@modelcontextprotocol/server-slack'], {
    stdio: 'inherit',
    env: process.env,
    windowsHide: true,
  });

  child.on('exit', (code, signal) => {
    if (signal) {
      process.kill(process.pid, signal);
      return;
    }
    process.exit(code ?? 0);
  });

  child.on('error', (error) => {
    console.error(`Failed to start npx: ${error.message}`);
    process.exit(1);
  });
})().catch((error) => {
  console.error(error.message);
  process.exit(1);
});
