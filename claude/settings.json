{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(npx vite build:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(strings ~/Library/Developer/Xcode/DerivedData/MonitorControl-*/Build/Products/Debug/MonitorControl.app/Contents/Resources/Base.lproj/Main.storyboardc/*.nib)",
      "mcp__Neon__list_projects"
    ]
  },
  "model": "claude-fable-5[1m]",
  "statusLine": {
    "type": "command",
    "command": "jq -r '(.context_window // {}) as $c | ($c.used_percentage // 0) as $p | (if $p >= 80 then \"\\u001b[31m\" elif $p >= 50 then \"\\u001b[33m\" else \"\\u001b[32m\" end) as $col | \"\\($col)ctx \\($p | floor)%\\u001b[0m\"'"
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true
}
