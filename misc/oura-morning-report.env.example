# Copy to ~/.config/oura-morning-report/config.env and fill in local secrets.

# Oura Personal Access Token:
# https://cloud.ouraring.com/personal-access-tokens
OURA_API_KEY=

# Slack Incoming Webhook URL.
# If omitted, the command also falls back to SLACK_WEBHOOK_URL and the existing
# Screenpipe break webhook config when available.
OURA_SLACK_WEBHOOK_URL=

# Scheduled runs only post inside this local time window.
OURA_REPORT_WINDOW_START=06:00
OURA_REPORT_WINDOW_END=12:00

# launchd interval in seconds. The script deduplicates reports per sleep day.
OURA_REPORT_START_INTERVAL_SECONDS=1800

# Include previous-day activity score, steps, and calories in the Slack message.
OURA_REPORT_INCLUDE_ACTIVITY=true
