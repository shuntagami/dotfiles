{
  "mcpServers": {
    "google-calendar": {
      "command": "/opt/homebrew/bin/node",
      "args": [
        "/Users/shun.tagami/projects/google-calendar-mcp/build/index.js"
      ],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/Users/shun.tagami/dotfiles/misc/gcp-oauth.keys.json"
